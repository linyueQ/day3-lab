{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://group-workshop.local/schemas/grading-score.schema.json",
  "title": "GradingScore",
  "description": "单个项目单侧（前端或后端）的评分 JSON，供班级 leaderboard 聚合。与 report-template.md 一一对应。",
  "type": "object",
  "required": ["team", "side", "total", "grade", "dimensions", "graded_at"],
  "additionalProperties": false,
  "properties": {
    "team": {
      "type": "string",
      "description": "队伍标识，kebab-case，例如 'team-01' 或 'sparrow'。",
      "minLength": 1
    },
    "side": {
      "type": "string",
      "enum": ["frontend", "backend"]
    },
    "total": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "按 rubric-scale.md §3 公式计算的 0–100 加权总分（N/A 不计入分母）。"
    },
    "grade": {
      "type": "string",
      "enum": ["S", "A", "B", "C", "D"],
      "description": "S≥90 / A 80-89 / B 70-79 / C 60-69 / D<60"
    },
    "dimensions": {
      "type": "array",
      "minItems": 1,
      "description": "前端 10 项 / 后端 9 项，顺序与 SKILL.md 中的维度编号一致。",
      "items": {
        "type": "object",
        "required": ["name", "score", "weight", "weighted"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "description": "维度 slug（kebab-case），须与 SKILL.md 对应维度一一映射。",
            "minLength": 1
          },
          "score": {
            "type": ["number", "null"],
            "minimum": 0,
            "maximum": 10,
            "description": "0–10 整数，或 null 表示 N/A / EVIDENCE_MISSING。"
          },
          "weight": {
            "type": "number",
            "minimum": 0,
            "maximum": 100
          },
          "weighted": {
            "type": "number",
            "minimum": 0,
            "maximum": 100,
            "description": "score × weight / 10；score 为 null 时填 0。"
          },
          "na_reason": {
            "type": "string",
            "description": "score 为 null 时必填：'spec §X.Y 未涉及' / 'EVIDENCE_MISSING: ...' / '技术栈无此概念'。"
          }
        },
        "allOf": [
          {
            "if": { "properties": { "score": { "type": "null" } } },
            "then": { "required": ["na_reason"] }
          }
        ]
      }
    },
    "top_fixes": {
      "type": "array",
      "description": "最该优先修的改进建议，按严重度降序。",
      "maxItems": 5,
      "items": { "type": "string", "minLength": 1 }
    },
    "evidence_count": {
      "type": "integer",
      "minimum": 0,
      "description": "报告中所有维度证据条数之和，用于抽检评分质量。"
    },
    "spec_sha": {
      "type": "string",
      "description": "spec 文件/仓库的 git sha 或版本标识。"
    },
    "project_sha": {
      "type": "string",
      "description": "被评项目 commit sha。"
    },
    "graded_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 时间戳。"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "side": { "const": "frontend" } },
        "required": ["side"]
      },
      "then": {
        "properties": {
          "dimensions": {
            "type": "array",
            "minItems": 10,
            "maxItems": 10,
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "enum": [
                    "spec-conformance",
                    "theme-aesthetic",
                    "animation",
                    "state-completeness",
                    "code-quality",
                    "responsive",
                    "forms",
                    "performance",
                    "a11y",
                    "microcopy"
                  ]
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": { "side": { "const": "backend" } },
        "required": ["side"]
      },
      "then": {
        "properties": {
          "dimensions": {
            "type": "array",
            "minItems": 9,
            "maxItems": 9,
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "enum": [
                    "spec-conformance",
                    "robustness",
                    "api-design",
                    "testing",
                    "data-modeling",
                    "layering",
                    "performance",
                    "observability",
                    "documentation"
                  ]
                }
              }
            }
          }
        }
      }
    }
  ]
}
